# Frontend environment variables for production
# Copy this to .env.local for local dev, or set these in Vercel dashboard

# Base URL of your Render backend (no trailing slash)
# Example: https://smarthomeapplianceshub-backend.onrender.com
VITE_API_URL=https://smarthomeapplianceshub-backend.onrender.com

# Admin API base URL (uses VITE_API_URL prefix automatically)
VITE_ADMIN_API_URL=https://smarthomeapplianceshub-backend.onrender.com/api
